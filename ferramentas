<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Preview — Seção Ferramentas | LuidySec</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=JetBrains+Mono:wght@400;500&family=Inter:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root{
    color-scheme: light only;
    --accent:#00c2ff;
    --ink:#0d1117;
    --muted:#5b6470;
    --line:#e6e9ee;
    --bg-soft:#f7f9fb;
  }
  *{box-sizing:border-box;}
  body{
    margin:0;
    background:#fff;
    color:var(--ink);
    font-family:'Inter', sans-serif;
    padding:60px 8%;
  }

  /* ===== SEÇÃO FERRAMENTAS — copiar daqui pra baixo ===== */

  .ferramentas{
    max-width:1100px;
    margin:0 auto;
  }
  .ferramentas .tag{
    font-family:'JetBrains Mono', monospace;
    font-size:.75rem;
    letter-spacing:.08em;
    text-transform:uppercase;
    color:var(--accent);
  }
  .ferramentas h2{
    font-family:'Space Grotesk', sans-serif;
    font-size:2rem;
    margin:.4rem 0 .6rem;
  }
  .ferramentas .lead{
    color:var(--muted);
    max-width:560px;
    margin-bottom:2rem;
    line-height:1.5;
  }

  .tools-search{
    margin-bottom:1.4rem;
  }
  .tools-search input{
    width:100%;
    max-width:360px;
    padding:.7rem 1rem;
    border:1px solid var(--line);
    border-radius:8px;
    font-family:'JetBrains Mono', monospace;
    font-size:.85rem;
    background:var(--bg-soft);
    color:var(--ink);
    outline:none;
    transition:border-color .2s;
  }
  .tools-search input:focus{
    border-color:var(--accent);
  }
  .tools-count{
    font-family:'JetBrains Mono', monospace;
    font-size:.75rem;
    color:var(--muted);
    margin-left:.8rem;
  }

  .tools-table-wrap{
    border:1px solid var(--line);
    border-radius:12px;
    overflow:hidden;
  }
  table.tools-table{
    width:100%;
    border-collapse:collapse;
    font-size:.9rem;
  }
  .tools-table thead{
    background:var(--bg-soft);
  }
  .tools-table th{
    text-align:left;
    padding:.85rem 1rem;
    font-family:'JetBrains Mono', monospace;
    font-size:.72rem;
    letter-spacing:.06em;
    text-transform:uppercase;
    color:var(--muted);
    border-bottom:1px solid var(--line);
    white-space:nowrap;
  }
  .tools-table td{
    padding:.85rem 1rem;
    border-bottom:1px solid var(--line);
    vertical-align:middle;
  }
  .tools-table tbody tr:last-child td{
    border-bottom:none;
  }
  .tools-table tbody tr{
    transition:background .15s;
  }
  .tools-table tbody tr:hover{
    background:var(--bg-soft);
  }
  .tool-name{
    font-weight:600;
  }
  .tool-cat{
    font-family:'JetBrains Mono', monospace;
    font-size:.75rem;
    color:var(--accent);
  }
  .tool-version{
    font-family:'JetBrains Mono', monospace;
    font-size:.8rem;
    color:var(--muted);
  }
  .tool-desc{
    color:var(--muted);
    max-width:320px;
  }
  .tool-dl{
    text-align:right;
    white-space:nowrap;
  }
  .dl-btn{
    display:inline-block;
    padding:.4rem .9rem;
    border-radius:20px;
    background:var(--ink);
    color:#fff;
    text-decoration:none;
    font-family:'JetBrains Mono', monospace;
    font-size:.75rem;
    transition:background .2s;
  }
  .dl-btn:hover{
    background:var(--accent);
    color:#0d1117;
  }
  .tools-empty{
    display:none;
    padding:2rem;
    text-align:center;
    color:var(--muted);
    font-family:'JetBrains Mono', monospace;
    font-size:.85rem;
  }

  @media (max-width: 700px){
    .tool-desc{display:none;}
    .tools-table th:nth-child(4){display:none;}
  }

  /* ===== fim da seção Ferramentas ===== */
</style>
</head>
<body>

<section id="ferramentas" class="ferramentas">
  <span class="tag">Download</span>
  <h2>Ferramentas</h2>
  <p class="lead">Utilitários e scripts que uso no dia a dia de suporte e infraestrutura, disponibilizados aqui para quem quiser baixar e usar.</p>

  <div class="tools-search">
    <input type="text" id="toolFilter" placeholder="Buscar por nome ou categoria..." oninput="filterTools()">
    <span class="tools-count" id="toolsCount"></span>
  </div>

  <div class="tools-table-wrap">
    <table class="tools-table" id="toolsTable">
      <thead>
        <tr>
          <th>Nome</th>
          <th>Categoria</th>
          <th>Versão</th>
          <th>Descrição</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <!-- Cada <tr> é uma ferramenta. Copie um bloco por item, ajuste o texto e o link do botão. -->
        <tr>
          <td class="tool-name">DiskClean</td>
          <td class="tool-cat">Manutenção</td>
          <td class="tool-version">v1.2</td>
          <td class="tool-desc">Script de limpeza de arquivos temporários e cache do Windows.</td>
          <td class="tool-dl"><a class="dl-btn" href="https://github.com/luidyai/hanna/releases/download/v1.2/diskclean.zip">↓ Baixar</a></td>
        </tr>
        <tr>
          <td class="tool-name">NetScan Lite</td>
          <td class="tool-cat">Redes</td>
          <td class="tool-version">v0.9</td>
          <td class="tool-desc">Varredura simples de dispositivos ativos na rede local.</td>
          <td class="tool-dl"><a class="dl-btn" href="https://github.com/luidyai/hanna/releases/download/v0.9/netscan-lite.zip">↓ Baixar</a></td>
        </tr>
        <tr>
          <td class="tool-name">BackupSync</td>
          <td class="tool-cat">Segurança & Backup</td>
          <td class="tool-version">v2.0</td>
          <td class="tool-desc">Rotina de backup incremental para pastas locais e externas.</td>
          <td class="tool-dl"><a class="dl-btn" href="https://github.com/luidyai/hanna/releases/download/v2.0/backupsync.zip">↓ Baixar</a></td>
        </tr>
        <tr>
          <td class="tool-name">LogViewer</td>
          <td class="tool-cat">Linux</td>
          <td class="tool-version">v1.0</td>
          <td class="tool-desc">Visualizador rápido de logs do sistema em terminal.</td>
          <td class="tool-dl"><a class="dl-btn" href="https://github.com/luidyai/hanna/releases/download/v1.0/logviewer.tar.gz">↓ Baixar</a></td>
        </tr>
        <tr>
          <td class="tool-name">PortCheck</td>
          <td class="tool-cat">Redes</td>
          <td class="tool-version">v1.1</td>
          <td class="tool-desc">Verificação rápida de portas abertas em um host.</td>
          <td class="tool-dl"><a class="dl-btn" href="https://github.com/luidyai/hanna/releases/download/v1.1/portcheck.zip">↓ Baixar</a></td>
        </tr>
        <!-- adicione mais linhas seguindo o mesmo padrão -->
      </tbody>
    </table>
    <div class="tools-empty" id="toolsEmpty">Nenhuma ferramenta encontrada.</div>
  </div>
</section>

<script>
  function filterTools(){
    const q = document.getElementById('toolFilter').value.trim().toLowerCase();
    const rows = document.querySelectorAll('#toolsTable tbody tr');
    let visible = 0;
    rows.forEach(row => {
      const text = row.innerText.toLowerCase();
      const match = text.includes(q);
      row.style.display = match ? '' : 'none';
      if(match) visible++;
    });
    document.getElementById('toolsCount').textContent = visible + ' de ' + rows.length;
    document.getElementById('toolsEmpty').style.display = visible === 0 ? 'block' : 'none';
  }
  filterTools();
</script>

</body>
</html>
